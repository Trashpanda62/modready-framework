      <VisualState SuggestedWidth="400" SuggestedHeight="233" State="Default" />
      <VisualState SuggestedWidth="402" SuggestedHeight="235" State="Hovered" />
      <VisualState SuggestedWidth="398" SuggestedHeight="231" State="Pressed" />
