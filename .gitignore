# Build artifacts -------------------------------------------------------------
bin/
obj/
dist/
*.dll
*.pdb
*.exe

# Allow the bundled third-party DLLs we redistribute under their licenses
!bundled-deps/**/*.dll

# Logs ------------------------------------------------------------------------
*.log
*.log.*
build.log
build-debug.log
blse-latest.log
*.archive-*.log
runtime-*.log

# Ralph snapshot/report files -------------------------------------------------
.ralph-snapshot/
ralph-report-*.txt
ralph-report-*.txt.build

# Editor/IDE ------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS noise --------------------------------------------------------------------
Thumbs.db
.DS_Store
desktop.ini

# Generated XML dumps from runtime --------------------------------------------
PatchedOptions.dump.xml
merged-*.xml

# Shield-fixture build output + dev flag (Phase 3 gate; never shipped) ---------
tools/shield-fixture/bin/
shieldfixture-path.flag

# Repo-root module staging folders (pre-dist workflow remnant, deleted Phase 4;
# the canonical pipeline is src -> dist\Modules -> deploy/zip/installer) -------
/BetaDeps/
/Bannerlord.Harmony/
/Bannerlord.UIExtenderEx/
/Bannerlord.ButterLib/
/Bannerlord.MBOptionScreen/

# NuGet -----------------------------------------------------------------------
*.nupkg
*.snupkg
packages/
.nuget/

# CI / local secrets ----------------------------------------------------------
.env
.env.local
*.local.json

# Local development notes / scripts (not part of the shipped mod) -------------
CLAUDE.md
scripts/

# Reflection / decompile scratch (local-only, regenerated on demand) ----------
decomp/
dump-*.ps1
find-*.ps1
reflect-*.ps1
scan-modules.ps1

# Steam SDK / uploader local artifacts ----------------------------------------
steam_appid.txt
steam_workshop_uploader.txt

# All-in-One installer staged payload (regenerated by Build-Installer.ps1)
installer/payload/

# FUSE deletion artifacts (from editing on a mounted filesystem) ----------------
.fuse_hidden*
test-disk-write.txt
