<?xml version="1.0" encoding="UTF-8"?>
<!--
  BetaDeps alias stub for Bannerlord.UIExtenderEx.

  Same pattern as the Bannerlord.Harmony alias: this folder exists so that
  consumer mods declaring <DependedModule Id="Bannerlord.UIExtenderEx" />
  find a module with that Id in the launcher. No DLLs are loaded by the
  alias as a SubModule; the actual UIExtenderEx work is done by
  Bannerlord.UIExtenderEx.dll inside Modules\BetaDeps\, which loads via
  the BetaDeps SubModule.xml.

  The alias's bin folder is populated with a copy of Bannerlord.UIExtenderEx.dll
  by the build script so any BLSE-style structural check finds the file on
  disk where it expects.
-->
<Module xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/BUTR/Bannerlord.XmlSchemas/master/SubModule.xsd">
  <Id value="Bannerlord.UIExtenderEx" />
  <Name value="Bannerlord.UIExtenderEx (provided by BetaDeps)" />
  <!-- Impersonate the upstream BUTR release line so any version check downstream passes. -->
  <Version value="v2.13.2" />
  <DefaultModule value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <Url value="" />

  <DependedModules>
    <DependedModule Id="BetaDeps" />
    <DependedModule Id="Bannerlord.Harmony" />
  </DependedModules>

  <ModulesToLoadAfterThis>
    <Module Id="BetaDeps" />
  </ModulesToLoadAfterThis>

  <DependedModuleMetadatas />

  <SubModules />
</Module>
