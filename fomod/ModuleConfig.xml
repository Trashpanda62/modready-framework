<?xml version="1.0" encoding="UTF-8"?>
<!--
  Vortex / FOMOD ModuleConfig.xml. Lives at the zip ROOT alongside Modules\.

  Read by the FOMOD Installer extension to drive the install wizard. The
  wizard structure:
    Step 1 ("Read this first") -- mandatory acknowledgement of which 4 mods
                                  to disable + how to handle conflicts.
    Step 2 ("Install")          -- single required-files group that deploys
                                  the entire Modules\ tree (BetaDeps + the
                                  four impersonation alias folders).

  Users without the FOMOD Installer extension don't see this wizard --
  Vortex falls back to a flat extract, which is also fine because every
  file in the zip ships under the standard Modules\ path the game expects.
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">

  <moduleName>BetaDeps</moduleName>

  <installSteps order="Explicit">

    <installStep name="Read this first">
      <optionalFileGroups order="Explicit">

        <group name="Before you click Install" type="SelectAtLeastOne">
          <plugins order="Explicit">

            <plugin name="I have disabled Bannerlord.Harmony / UIExtenderEx / ButterLib / MBOptionScreen in my Vortex mod list">
              <description>
BetaDeps replaces all four of those mods.

Before installing, in your Vortex mod list TOGGLE OFF (do not uninstall,
just disable):

  * Bannerlord.Harmony
  * Bannerlord.UIExtenderEx
  * Bannerlord.ButterLib
  * Bannerlord.MBOptionScreen

If left enabled they'll fight BetaDeps for the AppDomain slot and roughly
half your mod list will silently fail to load.

When Vortex shows a conflict prompt for 0Harmony.dll / Mono.Cecil / etc.,
let BetaDeps WIN every override.

Check this box to confirm you've done the above, then click Next.
              </description>
              <typeDescriptor>
                <type name="Recommended"/>
              </typeDescriptor>
            </plugin>

          </plugins>
        </group>

      </optionalFileGroups>
    </installStep>

    <installStep name="Install">
      <optionalFileGroups order="Explicit">

        <group name="BetaDeps core" type="SelectExactlyOne">
          <plugins order="Explicit">

            <plugin name="Install BetaDeps">
              <description>
Installs Modules\BetaDeps\ with all four impersonation alias folders
(Bannerlord.Harmony, Bannerlord.UIExtenderEx, Bannerlord.ButterLib,
Bannerlord.MBOptionScreen). After install, launch the game once via BLSE
LauncherEx so BetaDeps can write its first runtime snapshot.
              </description>
              <files>
                <!-- Deploy the entire Modules\ subtree from the zip root.
                     Vortex's Bannerlord mod-type knows to map "Modules\"
                     in the zip to "Modules\" in the game install. -->
                <folder source="Modules" destination="Modules" priority="0"/>
              </files>
              <typeDescriptor>
                <type name="Required"/>
              </typeDescriptor>
            </plugin>

          </plugins>
        </group>

      </optionalFileGroups>
    </installStep>

  </installSteps>

</config>
