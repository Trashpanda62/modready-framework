<?xml version="1.0" encoding="UTF-8"?>
<!--
  BetaDeps alias stub for Bannerlord.Harmony.

  This module folder exists so that consumer mods which declare
    <DependedModule Id="Bannerlord.Harmony" />
  in their own SubModule.xml find a module with that Id in the
  launcher and let the user enable them.

  No DLLs ship here. All Harmony functionality is provided by the
  BetaDeps module. The DependedModules section below forces the
  launcher to require BetaDeps to be enabled when this alias is
  enabled, which is the only behavior we want from this stub.
-->
<Module xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/BUTR/Bannerlord.XmlSchemas/master/SubModule.xsd">
  <Id value="Bannerlord.Harmony" />
  <Name value="Bannerlord.Harmony (provided by BetaDeps)" />
  <!-- Version impersonates the upstream BUTR Bannerlord.Harmony release line
       so BLSE's preflight check ("At least v2.2.2.x is required") passes.
       The 0Harmony.dll we actually ship is Lib.Harmony 2.3.x. -->
  <Version value="v2.3.4" />
  <DefaultModule value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <Url value="" />

  <DependedModules>
    <DependedModule Id="BetaDeps" />
  </DependedModules>

  <ModulesToLoadAfterThis>
    <Module Id="BetaDeps" />
  </ModulesToLoadAfterThis>

  <DependedModuleMetadatas />

  <SubModules />
</Module>
