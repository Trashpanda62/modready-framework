<?xml version="1.0" encoding="UTF-8"?>
<Module xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/BUTR/Bannerlord.XmlSchemas/master/SubModule.xsd">
  <Id value="BetaDeps" />
  <Name value="Bannerlord Beta Dependencies" />
  <Version value="v0.9.2" />
  <DefaultModule value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <Url value="3741426797" />

  <!-- v0.8 step 1: depend on Bannerlord.Harmony (now a real module, not an
       alias stub) so the Harmony binary fan loads into the AppDomain BEFORE
       BetaDeps's SubModule classes JIT. This puts every consumer mod that
       declares <DependedModule Id="Bannerlord.Harmony" /> on the same Harmony
       copy as our PatchShield / SaveShield infrastructure.

       v0.8 step 2: same pattern extended to Bannerlord.UIExtenderEx. Its
       SubModule (BetaDepsUIExtenderExSubModule) now runs from the
       Bannerlord.UIExtenderEx module's own bin, before BetaDeps. The
       corresponding <SubModule> entry was removed from this file's
       <SubModules> block below; that load is owned by the real module now. -->
  <DependedModules>
    <DependedModule Id="Bannerlord.Harmony" DependentVersion="v2.4.99.0" />
    <DependedModule Id="Bannerlord.UIExtenderEx" DependentVersion="v2.14.99.0" />
    <!-- v0.8 step 3: ButterLib promoted to a real module too. Its SubModule
         (ButterLibSubModule) now runs from Modules\Bannerlord.ButterLib\bin\
         BEFORE BetaDeps's MCM tab construction needs ButterLib's DI container. -->
    <DependedModule Id="Bannerlord.ButterLib" DependentVersion="v2.10.99.0" />
    <!-- v0.8 step 4 (final): MBOptionScreen / MCM promoted. Both MCMSubModule
         and MCMUISubModule now run from Modules\Bannerlord.MBOptionScreen\bin\.
         BetaDeps's OptionsVMMixin runs after MCM has registered, picking up
         every Settings instance from the same SettingsRegistry. -->
    <DependedModule Id="Bannerlord.MBOptionScreen" DependentVersion="v5.11.99.0" />
  </DependedModules>

  <!-- BetaDeps must load before:
       1. The official TaleWorlds stack (so Mission / Module / ApplicationVersion
          are reflectable for VersionProbe).
       2. Every BUTR-consuming community mod that might ship a bundled copy of
          MCMv5 / 0Harmony / UIExtenderEx / ButterLib / Newtonsoft.Json. The
          first MCMv5.dll to win the AppDomain slot wins for the entire session;
          if a consumer mod's bundled v5.10.x upstream copy wins, our MCMSubModule
          class doesn't exist in the loaded assembly and BetaDeps fails silently.
       Listing them here guarantees the launcher constructs BetaDeps first so
       BetaDeps.Foundation's [ModuleInitializer] installs the AssemblyResolve
       hook BEFORE any consumer mod's bundled copy is touched. -->
  <ModulesToLoadAfterThis>
    <!-- TaleWorlds stack -->
    <Module Id="Native" />
    <Module Id="SandBoxCore" />
    <Module Id="Sandbox" />
    <Module Id="StoryMode" />
    <Module Id="CustomBattle" />
    <!-- BUTR alias modules: all four were promoted to real DependedModules
         in v0.8 steps 1-4. None remain in the load-after list (they all
         load BEFORE BetaDeps now via the <DependedModules> block above). -->
    <!-- Consumer mods known to bundle MCMv5 / 0Harmony copies. Adding here
         pins our load order ahead of theirs regardless of dependency graph. -->
    <Module Id="DismembermentPlus" />
    <Module Id="XorberaxLegacy" />
    <Module Id="DynaCulture" />
    <Module Id="ArtemsLivelyAnimations" />
    <!-- Major BUTR consumers in the user's mod list. Pinning order here costs
         nothing if they're not installed - the launcher just ignores
         unknown Ids. -->
    <Module Id="FluidCombatLite" />
    <Module Id="Fluid_Combat_Lite" />
    <Module Id="BetterSmithing" />
    <Module Id="FasterTime" />
    <Module Id="BanditBlackHole" />
    <Module Id="PerfectFireArrows" />
    <Module Id="IDontCare" />
    <Module Id="ArtemsLivelyAnimations" />
    <Module Id="ImprovedGarrisons" />
    <Module Id="DistinguishedService" />
    <Module Id="CulturedStartV2" />
    <Module Id="DiplomacyFixes" />
    <Module Id="Diplomacy" />
    <Module Id="CalradiaExpanded" />
    <Module Id="CalradiaExpandedKingdoms" />
    <Module Id="CargoHolds" />
    <Module Id="CrashDoctor" />
    <Module Id="AchievementUnblocker" />
    <Module Id="CREST" />
    <Module Id="Crest" />
  </ModulesToLoadAfterThis>

  <DependedModuleMetadatas>
    <DependedModuleMetadata id="Bannerlord.Harmony" order="LoadBeforeThis" version="v2.4.99.0" />
    <DependedModuleMetadata id="Bannerlord.UIExtenderEx" order="LoadBeforeThis" version="v2.14.99.0" />
    <DependedModuleMetadata id="Bannerlord.ButterLib" order="LoadBeforeThis" version="v2.10.99.0" />
    <DependedModuleMetadata id="Bannerlord.MBOptionScreen" order="LoadBeforeThis" version="v5.11.99.0" />
  </DependedModuleMetadatas>

  <SubModules>
    <SubModule>
      <Name value="BetaDeps Harmony" />
      <DLLName value="BetaDeps.Harmony.dll" />
      <SubModuleClassType value="BetaDeps.Harmony.BetaDepsHarmonySubModule" />
      <Assemblies>
        <!-- BetaDeps.Foundation.dll: its [ModuleInitializer] installs the
             AssemblyResolve hook that redirects MCMv5/UIExtenderEx/etc.
             requests to our copies.

             v0.8 step 1: the Harmony binary fan (0Harmony.dll, Mono.Cecil.dll,
             and the five MonoMod.*.dll files) was REMOVED from this Assemblies
             block. Those DLLs now load via the real Bannerlord.Harmony module
             (Modules\Bannerlord.Harmony\bin\Win64_Shipping_Client\), which
             constructs BEFORE BetaDeps because of the <DependedModule> entry
             above. By the time this assembly is JIT'd, Harmony is already
             resolvable in the AppDomain. -->
        <Assembly value="BetaDeps.Foundation.dll" />
      </Assemblies>
      <Tags />
    </SubModule>
    <!-- v0.8 step 2: BetaDepsUIExtenderExSubModule now loads from the real
         Bannerlord.UIExtenderEx module (Modules\Bannerlord.UIExtenderEx\) so
         Bannerlord.UIExtenderEx.dll is in the AppDomain before BetaDeps's
         own ButterLib/MCM SubModules JIT (they both reference UIExtenderEx
         types). The DependedModule entry above pins the load order. -->
    <!-- v0.8 step 3: ButterLibSubModule now loads from the real
         Bannerlord.ButterLib module (Modules\Bannerlord.ButterLib\) so the
         DI container is built BEFORE BetaDeps's own MCM tab construction
         needs ButterLib services. The DependedModule entry above pins the
         load order; the Assemblies block (DI runtime + Serilog) moved into
         the real module's SubModule.xml. -->
    <!-- v0.8 step 4: MCMSubModule + MCMUISubModule both now load from the
         real Bannerlord.MBOptionScreen module (Modules\Bannerlord.MBOptionScreen\).
         The DependedModule entry above pins the load order. MCMv5.dll and
         Newtonsoft.Json.dll live exclusively in the real module's bin. -->
  </SubModules>
</Module>
