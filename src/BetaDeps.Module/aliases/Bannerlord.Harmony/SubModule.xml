<?xml version="1.0" encoding="UTF-8"?>
<!--
  v0.8 step 1: REAL Bannerlord.Harmony module (no longer an alias stub).

  Loads BEFORE BetaDeps because BetaDeps's SubModule.xml now carries
  <DependedModule Id="Bannerlord.Harmony" />. That ordering puts the
  Harmony binary fan (0Harmony.dll + Mono.Cecil.dll + the five MonoMod.*.dll
  files) into the AppDomain before BetaDeps's own SubModule classes JIT,
  which is the whole point of step 1: consumer mods that DependedModule us
  via Bannerlord.Harmony share the same Harmony copy as our PatchShield /
  SaveShield infrastructure, eliminating the "two Harmony copies" failure
  mode that drove BLSE's preflight quirk and the "Missing Bannerlord.Harmony
  a0.0.0.0 to a0.0.0.0" load-order popup.

  Version v2.4.99.0 stays — BLSE's preflight compares 4-part versions
  left-to-right and our v2.4.99 satisfies any reasonable v2.4.x minimum.
  Known dependents that declare minimum versions in v2.4.x range:
    Character Development Editor v1.0.10 requires Harmony v2.4.2
    XorberaxLegacy declares v2.4.* wildcard
    BLSE v2.2.2 minimum
  WARNING: legacy mods declaring strict v2.4.0.* wildcards (e.g. CargoHolds
  if still maintained) will NOT match v2.4.99.0. If reports come in we may
  need to revisit; modern modlist support takes precedence for now.

  The DependedModule on BetaDeps is intentionally REMOVED — this module
  must load first, not second. BetaDeps depends on us, not the other way
  around.
-->
<Module xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/BUTR/Bannerlord.XmlSchemas/master/SubModule.xsd">
  <Id value="Bannerlord.Harmony" />
  <Name value="Harmony" />
  <Version value="v2.4.99.0" />
  <DefaultModule value="false" />
  <SingleplayerModule value="true" />
  <MultiplayerModule value="true" />
  <Official value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <Url value="" />

  <DependedModules />

  <DependedModuleMetadatas />

  <SubModules>
    <SubModule>
      <Name value="Bannerlord.Harmony" />
      <DLLName value="Bannerlord.Harmony.dll" />
      <SubModuleClassType value="Bannerlord.Harmony.BannerlordHarmonySubModule" />
      <Assemblies>
        <!-- BetaDeps.Foundation.dll FIRST so its [ModuleInitializer] is
             primed before any Harmony reflection runs. The host SubModule
             logs via DiagLog which lives in Foundation. -->
        <Assembly value="BetaDeps.Foundation.dll" />
        <!-- Andreas Pardeike's Harmony, MIT, unmodified NuGet artifact. -->
        <Assembly value="0Harmony.dll" />
        <!-- Harmony 2.4.x transitive dependencies. Listed so the launcher
             preloads them in this module's AppDomain pass before any
             dependent module (BetaDeps + every consumer mod that DependedModule
             us) constructs. All MIT-licensed; copyright JB Evain (Cecil)
             and 0x0ade et al (MonoMod). -->
        <Assembly value="Mono.Cecil.dll" />
        <!-- Mono.Cecil.Mdb/Pdb/Rocks intentionally NOT shipped. They're symbol-
             reader / syntactic-sugar layers that Harmony's hot path doesn't
             touch. Saves ~160 KB on the public zip; if a future consumer mod
             needs them, re-add locally. -->
        <Assembly value="MonoMod.Backports.dll" />
        <Assembly value="MonoMod.Core.dll" />
        <Assembly value="MonoMod.Iced.dll" />
        <Assembly value="MonoMod.ILHelpers.dll" />
        <Assembly value="MonoMod.Utils.dll" />
        <!-- MonoMod.RuntimeDetour: 0Harmony's detour engine — the component
             that emits the trampoline IL at the first Patch(). MUST be preloaded
             from THIS module's platform bin like its siblings above. If it isn't,
             the on-demand resolver can bind the net472 copy from
             bin\Win64_Shipping_Client even inside a .NET 6 (Game Pass /
             Microsoft Store) process, whose ILGenerator lacks the net472-only
             MarkSequencePoint(ISymbolDocumentWriter,...) overload -> launch-time
             MissingMethodException. Listing it here forces the correct
             per-runtime copy (net6 on Gaming.Desktop, net472 on Win64). Steam
             never hit this because its process is net472 either way. -->
        <Assembly value="MonoMod.RuntimeDetour.dll" />
        <!-- BetaDeps.Harmony.dll (our shared Harmony helper layer, v0.9.0.0).
             MCMv5.dll, Bannerlord.UIExtenderEx.dll and Bannerlord.ButterLib.dll
             all carry a hard assembly reference to it. It used to resolve only
             from the BetaDeps module's bin, so any install WITHOUT the BetaDeps
             module (ModReady, or a Workshop sub to only the dependency items)
             left that reference dangling -> BLSE's loader returned CriticalError
             -> "MCM Submodule could not be loaded correctly due to a dependency
             conflict". Seeding it HERE (the first module to load, same as
             0Harmony) puts it in the AppDomain before those three modules
             construct, so their references resolve by simple-name binding. It
             depends only on Foundation + 0Harmony + MonoMod.Backports, all
             listed above, so it loads cleanly. Last so its deps are already in. -->
        <Assembly value="BetaDeps.Harmony.dll" />
      </Assemblies>
      <Tags />
    </SubModule>
  </SubModules>
</Module>
