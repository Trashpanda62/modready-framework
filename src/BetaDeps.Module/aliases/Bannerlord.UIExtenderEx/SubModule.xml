<?xml version="1.0" encoding="UTF-8"?>
<!--
  v0.8 step 2: REAL Bannerlord.UIExtenderEx module (no longer an alias stub).

  Same pattern as v0.8 step 1 promoted Bannerlord.Harmony to a real module:
  this folder now holds Bannerlord.UIExtenderEx.dll directly and runs its
  BetaDepsUIExtenderExSubModule class. Loads BEFORE BetaDeps because
  BetaDeps's SubModule.xml carries <DependedModule Id="Bannerlord.UIExtenderEx" />.

  Why: consumer mods that ship their own bundled copy of
  Bannerlord.UIExtenderEx.dll inside their own bin folder would otherwise
  win the AppDomain slot if they JIT'd first. Promoting our copy to a
  pre-BetaDeps module guarantees ours loads first, and consumer mods that
  DependedModule us on this Id share that copy.

  Load order in v0.8 step 2:
    Bannerlord.Harmony            (real module, step 1)
    Bannerlord.UIExtenderEx       (real module, this step)
    Bannerlord.ButterLib          (still alias stub — promoted in a later step)
    Bannerlord.MBOptionScreen     (still alias stub — promoted in a later step)
    BetaDeps                      (loads after all of the above)

  Version v2.14.99.0 retained from the previous stub. BLSE preflight does
  4-part left-to-right matching against any reasonable v2.x consumer mod
  minimum.

  DependedModule on BetaDeps REMOVED — we load before BetaDeps now.
  DependedModule on Bannerlord.Harmony retained — UIExtenderEx.dll
  references Harmony internally and the engine pins Harmony first.
-->
<Module xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/BUTR/Bannerlord.XmlSchemas/master/SubModule.xsd">
  <Id value="Bannerlord.UIExtenderEx" />
  <Name value="UIExtenderEx" />
  <Version value="v2.14.99.0" />
  <DefaultModule value="false" />
  <SingleplayerModule value="true" />
  <MultiplayerModule value="true" />
  <Official value="false" />
  <ModuleCategory value="Singleplayer" />
  <ModuleType value="Community" />
  <Url value="" />

  <DependedModules>
    <DependedModule Id="Bannerlord.Harmony" DependentVersion="v2.4.99.0" />
  </DependedModules>

  <DependedModuleMetadatas>
    <DependedModuleMetadata id="Bannerlord.Harmony" order="LoadBeforeThis" version="v2.4.99.0" />
  
    <DependedModuleMetadata id="Native" order="LoadAfterThis" version="v1.0.0.*" optional="true" />
    <DependedModuleMetadata id="SandBoxCore" order="LoadAfterThis" version="v1.0.0.*" optional="true" />
    <DependedModuleMetadata id="Sandbox" order="LoadAfterThis" version="v1.0.0.*" optional="true" />
    <DependedModuleMetadata id="StoryMode" order="LoadAfterThis" version="v1.0.0.*" optional="true" />
    <DependedModuleMetadata id="CustomBattle" order="LoadAfterThis" version="v1.0.0.*" optional="true" />
  </DependedModuleMetadatas>

  <ModulesToLoadAfterThis>
    <Module Id="Native" />
    <Module Id="SandBoxCore" />
    <Module Id="Sandbox" />
    <Module Id="StoryMode" />
    <Module Id="CustomBattle" />
  </ModulesToLoadAfterThis>

  <SubModules>
    <SubModule>
      <Name value="Bannerlord.UIExtenderEx" />
      <DLLName value="Bannerlord.UIExtenderEx.dll" />
      <SubModuleClassType value="Bannerlord.UIExtenderEx.BetaDepsUIExtenderExSubModule" />
      <Assemblies>
        <Assembly value="BetaDeps.Foundation.dll" />
        <Assembly value="Bannerlord.UIExtenderEx.dll" />
      </Assemblies>
      <Tags />
    </SubModule>
  </SubModules>
</Module>
