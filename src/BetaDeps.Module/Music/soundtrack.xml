<?xml version="1.0" encoding="utf-8"?>
<!--
  BetaDeps BYO adaptive music — PSAI project template.

  At runtime, PsaiRedirectManager (workstream C2) generates the real soundtrack
  by scanning Modules/BetaDeps/Music/BYO/<Context>/[<Culture>/]*.ogg and writing
  one Theme per active context into a copy of this file, then calling
  PsaiCore.LoadSoundtrackFromProjectFile(["Native","NavalDLC","BetaDeps"]).

  ModuleIdPrefix MUST stay 9000 — unique per module, prevents theme-id collision
  with Native (prefix 1) and NavalDLC (prefix 1024). Theme local-ids 1..N produce
  effective ids 90001..9000N via int.Parse(prefix + localId) string-concat.

  This template ships empty (no Themes). The runtime generator fills it in.
  Do not add manual segment entries here — they will be overwritten on load.
-->
<PsaiProject xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <SerializedByProtocolVersion>1.0</SerializedByProtocolVersion>
  <Properties>
    <ModuleIdPrefix>9000</ModuleIdPrefix>
    <WarningThresholdPreBeatMillis>1500</WarningThresholdPreBeatMillis>
    <DefaultCalculatePostAndPrebeatLengthBasedOnBeats>false</DefaultCalculatePostAndPrebeatLengthBasedOnBeats>
    <DefaultSegmentSuitabilites>3</DefaultSegmentSuitabilites>
    <ForceFullRebuild>true</ForceFullRebuild>
    <VolumeBoost>0</VolumeBoost>
    <ExportSoundQualityInPercent>100</ExportSoundQualityInPercent>
    <DefaultPrebeats>1</DefaultPrebeats>
    <DefaultPostbeats>4</DefaultPostbeats>
    <DefaultBpm>100</DefaultBpm>
    <DefaultPrebeatLengthInSamples>88200</DefaultPrebeatLengthInSamples>
    <DefaultPostbeatLengthInSamples>176400</DefaultPostbeatLengthInSamples>
  </Properties>
  <Themes />
</PsaiProject>
