<Brushes>

  <!-- Slice 3: native collapse chevrons. Two simple single-sprite brushes that
       point at Bannerlord's own collapser indicator sprites (the ones vanilla's
       GameKeys option groups use). We render them as plain visibility-toggled
       BrushWidgets in the Mod Config group header instead of the text ">" / "v",
       so the chevrons match the game's look exactly. -->

  <Brush Name="ModReady.Chevron.Closed">
    <Layers>
      <BrushLayer Name="Default" Sprite="SPGeneral\SPOptions\collapser_indicator_closed" />
    </Layers>
  </Brush>

  <Brush Name="ModReady.Chevron.Open">
    <Layers>
      <BrushLayer Name="Default" Sprite="SPGeneral\SPOptions\collapser_indicator_open" />
    </Layers>
  </Brush>

  <!-- Slice 4: mod-row hover highlight. Transparent by default; a faint white
       wash when the row's button is hovered (state propagated via the button's
       UpdateChildrenStates). -->
  <Brush Name="ModReady.RowHover">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" />
    </Layers>
    <Styles>
      <Style Name="Default"><BrushLayer Name="Default" Color="#FFFFFF00" /></Style>
      <Style Name="Hovered"><BrushLayer Name="Default" Color="#FFFFFF1A" /></Style>
    </Styles>
  </Brush>

  <!-- v0.9.2: settings-row hover highlight. Single solid amber layer, no states;
       visibility is driven by the row VM's @IsHovered binding (set from the
       HintWidget's reliable HoverBegin/End), NOT by button state propagation.
       BlankWhiteSquare_9 is globally loaded (same sprite as Panel.Background).
       v0.9.2: alpha dropped from B4 (~70%) to 26 (~15%) — the old wash was a
       loud opaque bar; this is a faint warm tint that reads as a subtle native
       hover. Same overlay now also fires for header rows (header button carries
       Command.HoverBegin/End). -->
  <Brush Name="ModReady.RowHover.Solid">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#F0A82826" />
    </Layers>
  </Brush>

  <!-- v0.9.2: left accent bar for nested sub-section headers. A bright solid
       gold vertical strip rendered at the indented left edge of every child
       header row, so sub-sections read as branched-off children at a glance:
       a far more obvious cue than text color alone. -->
  <Brush Name="ModReady.ChildAccent">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#E8C46EFF" />
    </Layers>
  </Brush>

  <!-- v0.9.2: PARENT section-header title bar. A gold wash behind the full row
       so top-level sections read as title bars; child sub-sections have NO
       background, making the parent/child tiers obvious at a glance. Uses the
       globally-loaded BlankWhiteSquare_9 (same sprite as the row hover, proven
       to render) rather than SPOptions.*.Background, which is near-transparent. -->
  <Brush Name="ModReady.ParentHeaderBg">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#C8A45C45" />
    </Layers>
  </Brush>

  <!-- Slice 5: contained-panel backing. The globally-loaded 9-slice BlankWhiteSquare_9
       tinted to semi-transparent black, sat behind the settings column to lift the
       text off the busy parallax background and read as a contained panel. -->
  <Brush Name="ModReady.Panel.Background">
    <Layers>
      <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" Color="#00000099" />
    </Layers>
  </Brush>

</Brushes>
