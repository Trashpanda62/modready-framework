//
// Harmony hook on WidgetPrefab.LoadFrom that routes prefab XML through
// PrefabPatcher before the game parses it.
//
// Strategy: prefix-patch with a ref string path parameter. When the prefab
// name matches one or more registered PrefabExtensionAttribute entries, we:
//   1. Read the original XML file.
//   2. Apply matching patches into an XmlDocument (PrefabPatcher.ApplyAll).
//   3. Write the modified XML to a temp file.
//   4. Redirect the path argument to point at the temp file.
//   5. In a postfix, schedule the temp file for cleanup.
//
// Why prefix-redirect rather than transpiler:
//   * The transpiler approach in upstream UIExtenderEx (Aragas) injects a
//     hook inside the parsing loop. Re-implementing that needs intimate
//     knowledge of the parser's IL, which shifts across game versions.
//   * File redirection is target-agnostic: we don't care how the parser
//     reads the file, we just hand it different bytes.
//   * Cost is one disk write per prefab open, which is rare.

using System;
using System.Threading;
using System.IO;
using System.Linq;
using System.Reflection;
using System.Xml;

using BetaDeps.Foundation;
using BetaDeps.Harmony;

using HarmonyLib;

namespace Bannerlord.UIExtenderEx.Runtime;

internal static class WidgetPrefabHook
{
    private const string Tag = "WidgetPrefabHook";
    private const string HarmonyId = "betadeps.uiextenderex.widgetprefab";

    private static int _installed;
    private static MethodInfo? _loadFromTarget;

    /// <summary>
    /// Install the Harmony prefix on WidgetPrefab.LoadFrom. Idempotent.
    /// Logs whether the bind succeeded or which fallback was selected.
    /// </summary>
    public static void Install()
    {
        if (System.Threading.Interlocked.CompareExchange(ref _installed, 1, 0) != 0) return;

        try
        {
            var widgetPrefabType = BetaDeps.Foundation.ReflectionUtils.ResolveTypeByFullName("TaleWorlds.GauntletUI.PrefabSystem.WidgetPrefab");
            if (widgetPrefabType == null)
            {
                DiagLog.Log(Tag, "TaleWorlds.GauntletUI.PrefabSystem.WidgetPrefab type not found; prefab patching disabled.");
                return;
            }

            // LoadFrom signatures vary by game version. We want the overload that
            // accepts a string (the prefab file path) as one of its arguments.
            // Take any LoadFrom with at least one string parameter.
            var candidates = widgetPrefabType
                .GetMethods(BindingFlags.Public | BindingFlags.NonPublic | BindingFlags.Static | BindingFlags.Instance)
                .Where(m => string.Equals(m.Name, "LoadFrom", StringComparison.Ordinal))
                .Where(m => m.GetParameters().Any(p => p.ParameterType == typeof(string)))
                .ToArray();

            if (candidates.Length == 0)
            {
                DiagLog.Log(Tag, $"WidgetPrefab has no LoadFrom overload accepting a string; prefab patching disabled. Available: [{string.Join(", ", widgetPrefabType.GetMethods().Where(m => m.Name == "LoadFrom").Select(m => $"{m.Name}({m.GetParameters().Length})"))}]");
                return;
            }

            // Prefer the overload with the fewest parameters -- usually the simpler entry point.
            _loadFromTarget = candidates.OrderBy(m => m.GetParameters().Length).First();
            DiagLog.Log(Tag, $"selected LoadFrom: {_loadFromTarget.DeclaringType?.FullName}.{_loadFromTarget.Name}({string.Join(", ", _loadFromTarget.GetParameters().Select(p => p.ParameterType.Name + " " + p.Name))})");

            var harmony = new HarmonyLib.Harmony(HarmonyId);
            var prefix  = new HarmonyMethod(typeof(WidgetPrefabHook), nameof(LoadFromPrefix));
            var postfix = new HarmonyMethod(typeof(WidgetPrefabHook), nameof(LoadFromPostfix));
            harmony.Patch(_loadFromTarget, prefix: prefix, postfix: postfix);
            DiagLog.Log(Tag, "installed prefix+postfix on WidgetPrefab.LoadFrom");
        }
        catch (Exception ex)
        {
            DiagLog.LogCaught(Tag, "Install", ex);
        }
    }

    /// <summary>
    /// Prefix: inspect the path argument. If any registered patch matches the
    /// prefab name, generate a modified XML temp file and redirect the path.
    /// </summary>
    public static void LoadFromPrefix(object[] __args, out string? __state)
    {
        __state = null;
        try
        {
            // Find the first string arg that points at an existing file.
            int pathIndex = -1;
            for (int i = 0; i < __args.Length; i++)
            {
                if (__args[i] is string s && !string.IsNullOrEmpty(s) && File.Exists(s))
                {
                    pathIndex = i;
                    break;
                }
            }
            if (pathIndex < 0) return;

            var originalPath = (string)__args[pathIndex];
            var movieName = Path.GetFileNameWithoutExtension(originalPath);

            // Collect every registered patch from every enabled UIExtender registry
            // whose Movie matches this prefab name.
            var matching = UIExtenderEngine.Enabled
                .SelectMany(r => r.Prefabs)
                .Where(p => string.Equals(p.Attribute.Movie, movieName, StringComparison.Ordinal))
                .ToList();

            // Diagnostic: if movieName matches any registered "interesting" prefab name
            // (case-insensitive substring of a registered Movie), log every visit so we
            // can verify the hook is reaching the prefabs we're trying to patch.
            // Use a set of names we care about to avoid log spam for every prefab loaded.
            if (ShouldLogPrefabLoad(movieName))
            {
                DiagLog.Log(Tag, $"LoadFrom called for movie '{movieName}' (path={originalPath}); registered patches matching this movie name: {matching.Count}");
            }

            if (matching.Count == 0) return;

            // Load + patch + write temp.
            var doc = new XmlDocument();
            doc.Load(originalPath);
            var applied = PrefabPatcher.ApplyAll(movieName, doc, matching);
            if (applied == 0)
            {
                DiagLog.Log(Tag, $"{movieName}: had {matching.Count} candidate patch(es), 0 applied (XPaths did not match -- see PrefabPatcher log for details)");
                return;
            }

            var tempPath = Path.Combine(Path.GetTempPath(),
                $"betadeps-prefab-{movieName}-{Guid.NewGuid():N}.xml");
            doc.Save(tempPath);
            __args[pathIndex] = tempPath;
            __state = tempPath;
            DiagLog.Log(Tag, $"redirected {movieName} -> temp file ({applied} patch(es) applied) [temp={tempPath}]");

            // v0.4.3 diagnostic: ALSO copy the merged-and-patched XML to
            // Modules\BetaDeps\merged-<movie>.xml. The source dump shows
            // what each patch contributes; this one shows what Bannerlord
            // actually parses. Survives game crashes for post-mortem.
            try
            {
                var rtPath = BetaDeps.Foundation.RuntimeLog.Path;
                var dir = Path.GetDirectoryName(rtPath);
                if (!string.IsNullOrEmpty(dir))
                {
                    var mergedDump = Path.Combine(dir, "merged-" + movieName + ".xml");
                    System.IO.File.Copy(tempPath, mergedDump, overwrite: true);
                    DiagLog.Log(Tag, $"  also copied merged XML to {mergedDump}");
                }
            }
            catch (Exception ex) { DiagLog.LogCaught(Tag, "merged-dump", ex); }
        }
        catch (Exception ex)
        {
            DiagLog.LogCaught(Tag, "LoadFromPrefix", ex);
        }
    }

    /// <summary>
    /// True for prefab names worth logging visits for. Catches anything that
    /// looks like an Options / settings / mod-related prefab so we can debug
    /// XPath mismatches without spamming the log for every Gauntlet movie.
    /// v0.6: switched from ToLowerInvariant() (allocates a new string per
    /// prefab load) to allocation-free OrdinalIgnoreCase IndexOf. Hot path
    /// during game start where hundreds of prefabs flow through.
    /// </summary>
    private static bool ShouldLogPrefabLoad(string movieName)
    {
        if (string.IsNullOrEmpty(movieName)) return false;
        return movieName.IndexOf("option",  StringComparison.OrdinalIgnoreCase) >= 0
            || movieName.IndexOf("setting", StringComparison.OrdinalIgnoreCase) >= 0
            || movieName.IndexOf("mod",     StringComparison.OrdinalIgnoreCase) >= 0
            || movieName.IndexOf("config",  StringComparison.OrdinalIgnoreCase) >= 0
            || movieName.IndexOf("keybind", StringComparison.OrdinalIgnoreCase) >= 0;
    }

    /// <summary>Postfix: clean up the temp file written by the prefix.</summary>
    public static void LoadFromPostfix(string? __state)
    {
        if (string.IsNullOrEmpty(__state)) return;
        try
        {
            if (File.Exists(__state)) File.Delete(__state);
        }
        catch { /* harmless leak; OS will clean %TEMP% eventually */ }
  